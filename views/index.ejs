<%- include('partials/header') %>

    <main class="container">
        <header style="text-align: center; margin-bottom: 30px;">
            <h1 style="color: #333;">Featured Products</h1>
            <form action="/products" method="GET" class="search-form" style="margin-top: 20px;">
                <input type="text" name="search" value="<%= search %>" placeholder="Search for products (e.g. Keyboard)..." 
                       style="padding: 10px; width: 300px; border-radius: 20px; border: 1px solid #ddd;">
                <button type="submit" class="btn" style="border-radius: 20px;">Search</button>
            </form>
        </header>

        <div class="product-container">
            <% if (products.length > 0) { %>
                <% products.forEach(p => { %>
                    <div class="card">
                        <img src="/<%= p.image %>" 
                             alt="<%= p.name %>" 
                             style="display: block; width: 100%; height: 200px; object-fit: contain; padding: 10px;" 
                             onerror="this.onerror=null; this.src='https://via.placeholder.com/300x200?text=Image+Not+Found';">
                        <div class="card-content">
                            <h3><%= p.name %></h3>
                            <p class="price">Rs. <%= p.price %></p>
                            <p class="category" style="color: #666; font-size: 0.9em;"><%= p.category %></p>
                            <a href="/products/<%= p._id %>" class="btn">View Details</a>
                            <form action="/add-to-cart/<%= p._id %>" method="POST">
    <button type="submit" class="btn" style="background: #28a745; margin-top: 5px; width: 100%;">Add to Cart</button>
</form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 50px;">
                    <p>No products found.</p>
                    <a href="/products" class="btn">Show All Products</a>
                </div>
            <% } %>
        </div>

        <% if (pages > 0) { %>
            <div class="pagination-container" style="text-align: center; margin: 50px 0; display: flex; justify-content: center; gap: 10px;">
                
                <% if (current == 1) { %>
                    <span class="btn disabled" style="background: #ccc; cursor: not-allowed;">First</span>
                <% } else { %>
                    <a href="/products?page=1<%= search ? '&search=' + search : '' %>" class="btn">First</a>
                <% } %>

                <% for (let i = 1; i <= pages; i++) { %>
                    <% if (i == current) { %>
                        <span class="btn" style="background: #2575fc; color: white;"><%= i %></span>
                    <% } else { %>
                        <a href="/products?page=<%= i %><%= search ? '&search=' + search : '' %>" class="btn" style="background: #f0f0f0; color: #333;"><%= i %></a>
                    <% } %>
                <% } %>

                <% if (current == pages) { %>
                    <span class="btn disabled" style="background: #ccc; cursor: not-allowed;">Last</span>
                <% } else { %>
                    <a href="/products?page=<%= pages %><%= search ? '&search=' + search : '' %>" class="btn">Last</a>
                <% } %>
                
            </div>
        <% } %>
        </main>

<%- include('partials/footer') %> ```



